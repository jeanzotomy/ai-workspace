# =============================================================================
# AI Workspace — Variables d'environnement
# =============================================================================
# INSTRUCTIONS :
#   1. Copier ce fichier en .env : `cp .env.example .env`
#   2. Remplir TOUTES les valeurs marquées <générer> via `make bootstrap`
#      (le script bootstrap.sh génère les secrets automatiquement)
#   3. Ne JAMAIS committer .env — il est dans .gitignore
#   4. En production : les clés API LLM sont gérées par Infisical (voir INTEGRATION.md)
#      et injectées via `infisical run` — le fallback .env est réservé au dev local.
# =============================================================================


# =============================================================================
## Global
# =============================================================================

# Domaine de base — tous les sous-domaines sont construits depuis cette variable
# Ex: ai.example.com → chat.ai.example.com, dify.ai.example.com, etc.
# En dev local : aiws.localhost (résolution via /etc/hosts ou dnsmasq)
DOMAIN=ai.example.com

# Email Let's Encrypt pour les certificats ACME (obligatoire en production)
ACME_EMAIL=admin@example.com

# Fuseau horaire des conteneurs
TZ=UTC

# Niveau de log Traefik (DEBUG, INFO, WARN, ERROR)
TRAEFIK_LOG_LEVEL=INFO


# =============================================================================
## PostgreSQL (instance partagée — multi-bases)
# =============================================================================

# Superutilisateur PostgreSQL (utilisé par init-multi-db.sh pour créer les bases)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<générer>  # min 32 caractères aléatoires

# Base par défaut du superutilisateur (ne pas modifier)
POSTGRES_DB=postgres

# Credentials par brique (créés par init-multi-db.sh)
# Authentik
AUTHENTIK_DB_USER=authentik
AUTHENTIK_DB_NAME=authentik
AUTHENTIK_DB_PASSWORD=<générer>

# Dify
DIFY_DB_USER=dify
DIFY_DB_NAME=dify
DIFY_DB_PASSWORD=<générer>

# Langfuse
LANGFUSE_DB_USER=langfuse
LANGFUSE_DB_NAME=langfuse
LANGFUSE_DB_PASSWORD=<générer>

# Infisical
INFISICAL_DB_USER=infisical
INFISICAL_DB_NAME=infisical
INFISICAL_DB_PASSWORD=<générer>

# Comp AI
COMPAI_DB_USER=compai
COMPAI_DB_NAME=compai
COMPAI_DB_PASSWORD=<générer>


# =============================================================================
## Redis (instance partagée)
# =============================================================================

REDIS_PASSWORD=<générer>  # min 32 caractères aléatoires
REDIS_MAXMEMORY=512mb


# =============================================================================
## MinIO (stockage objet S3-compatible)
# =============================================================================

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=<générer>  # min 16 caractères


# =============================================================================
## ClickHouse (analytics Langfuse)
# =============================================================================

CLICKHOUSE_DB=langfuse
CLICKHOUSE_USER=langfuse
CLICKHOUSE_PASSWORD=<générer>


# =============================================================================
## Traefik / ACME
# =============================================================================
# Voir ## Global — ACME_EMAIL et DOMAIN sont utilisés par Traefik


# =============================================================================
## Authentik (SSO IdP)
# =============================================================================

# Clé secrète principale — générer avec : openssl rand -hex 32
AUTHENTIK_SECRET_KEY=<générer>

# Compte admin créé au premier démarrage (changer le mot de passe après)
AUTHENTIK_BOOTSTRAP_EMAIL=admin@example.com
AUTHENTIK_BOOTSTRAP_PASSWORD=<générer>


# =============================================================================
## Email / SMTP (optionnel — invitations, reset de mot de passe)
# =============================================================================

# Laisser vide pour désactiver les emails (mode dev)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=true
SMTP_FROM=noreply@example.com


# =============================================================================
## Dify (orchestration IA)
# =============================================================================
# ⚠️ dify.yml est produit par l'agent devops-B — ces variables sont documentées
# ici pour référence et cohérence du .env global.

# Clé secrète Dify (Flask / sessions) — générer avec : openssl rand -hex 32
DIFY_SECRET_KEY=<générer>

# Mot de passe d'initialisation admin Dify (premier démarrage uniquement)
# CONTRAINTE Dify : ≤30 caractères, lettres + chiffres (un secret hex de 64 chars
# est refusé → 422 sur /console/api/init et installation impossible).
DIFY_INIT_PASSWORD=<générer>

# Clé API sandbox Dify (code execution) — générer avec : openssl rand -hex 32
DIFY_SANDBOX_API_KEY=<générer>

# Clé API Dify pour Open WebUI (créée depuis l'interface Dify après démarrage)
# Format : app-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DIFY_API_KEY=<créer depuis l'interface Dify>

# Version Dify (images langgenius/dify-api et langgenius/dify-web)
DIFY_VERSION=1.14.2
DIFY_SANDBOX_VERSION=0.2.15

# Qdrant (vector store) — partagé avec infra
QDRANT_API_KEY=<générer>

# MinIO — bucket Dify (créé par bootstrap.sh)
DIFY_S3_BUCKET=dify

# Type de stockage : s3 (MinIO) ou local (volume docker)
DIFY_STORAGE_TYPE=s3

# Log level Dify (DEBUG, INFO, WARNING, ERROR)
DIFY_LOG_LEVEL=INFO

# Variables Dify internes (voir dify.yml pour la liste complète)
DIFY_DB_USER=dify
# DIFY_DB_PASSWORD défini dans la section PostgreSQL ci-dessus

# Clés API LLM — PROD : gérer via Infisical, injecter avec `infisical run`
# DEV : remplir ici pour le développement local uniquement
OPENAI_API_KEY=<prod: gérer via Infisical>
ANTHROPIC_API_KEY=<prod: gérer via Infisical>
MISTRAL_API_KEY=<prod: gérer via Infisical>
AZURE_OPENAI_API_KEY=<prod: gérer via Infisical>
AZURE_OPENAI_ENDPOINT=


# =============================================================================
## Open WebUI
# =============================================================================

# Clé secrète session Open WebUI — générer avec : openssl rand -hex 32
OPENWEBUI_SECRET_KEY=<générer>

# OIDC Authentik — IDs créés lors de la configuration du provider dans Authentik
OPENWEBUI_OIDC_CLIENT_ID=<créer dans Authentik>
OPENWEBUI_OIDC_CLIENT_SECRET=<créer dans Authentik>

# Autoriser l'inscription libre (false = OIDC uniquement)
OPENWEBUI_ENABLE_SIGNUP=false

# Rôle par défaut des nouveaux utilisateurs (user, admin)
OPENWEBUI_DEFAULT_USER_ROLE=user

# OpenTelemetry vers Langfuse (optionnel)
OPENWEBUI_ENABLE_OTEL=false


# =============================================================================
## Langfuse (observabilité LLM)
# =============================================================================
# ⚠️ langfuse.yml est produit par l'agent devops-B — ces variables sont documentées
# ici pour référence et cohérence du .env global.

# Clé secrète Langfuse — générer avec : openssl rand -hex 32
LANGFUSE_SECRET_KEY=<générer>

# Clé publique Langfuse (partagée avec Dify et Open WebUI pour le tracing)
# Créée depuis l'interface Langfuse après démarrage > Paramètres > API Keys
LANGFUSE_PUBLIC_KEY=<créer depuis l'interface Langfuse>

# NextAuth secret pour Langfuse — générer avec : openssl rand -hex 32
LANGFUSE_NEXTAUTH_SECRET=<générer>

# Version Langfuse (images langfuse/langfuse et langfuse/langfuse-worker)
LANGFUSE_VERSION=3

# Bucket MinIO pour Langfuse (events, media, batch exports)
LANGFUSE_S3_BUCKET=langfuse

# OIDC Authentik pour Langfuse
LANGFUSE_OIDC_CLIENT_ID=<créer dans Authentik>
LANGFUSE_OIDC_CLIENT_SECRET=<créer dans Authentik>

# Slug de l'application Langfuse dans Authentik (utilisé pour construire l'ISSUER URL)
# Doit correspondre au slug du blueprint : config/authentik/blueprints/ai-workspace.yaml
LANGFUSE_OIDC_SLUG=langfuse
LANGFUSE_OIDC_PROVIDER_NAME=Authentik

# ClickHouse — utilisé par Langfuse v3 pour les traces analytics
# CLICKHOUSE_PASSWORD défini dans la section ClickHouse ci-dessus

# Salt pour les clés API Langfuse — générer avec : openssl rand -hex 16
LANGFUSE_SALT=<générer>

# Clé de chiffrement Langfuse (données sensibles au repos) — 64 caractères hex
# Générer avec : openssl rand -hex 32
LANGFUSE_ENCRYPTION_KEY=<générer>


# =============================================================================
## Infisical (gestionnaire de secrets)
# =============================================================================

# Clé de chiffrement — 16 octets hex = 32 caractères hex
# Générer avec : openssl rand -hex 16
INFISICAL_ENCRYPTION_KEY=<générer>

# Secret JWT — générer avec : openssl rand -hex 32
INFISICAL_AUTH_SECRET=<générer>


# =============================================================================
## Comp AI (conformité SOC2/ISO27001/RGPD)
# =============================================================================

# Secret NextAuth — générer avec : openssl rand -hex 32
COMPAI_NEXTAUTH_SECRET=<générer>

# OIDC/OAuth Authentik pour Comp AI
COMPAI_OIDC_CLIENT_ID=<créer dans Authentik>
COMPAI_OIDC_CLIENT_SECRET=<créer dans Authentik>

# Bucket MinIO pour les pièces justificatives de conformité
COMPAI_STORAGE_BUCKET=comp-ai-evidence
COMPAI_STORAGE_REGION=us-east-1

# =============================================================================
# RAPPEL SÉCURITÉ :
# - Toutes les valeurs <générer> sont créées automatiquement par `make bootstrap`
# - Les clés API LLM ne doivent JAMAIS être commitées — utiliser Infisical en prod
# - Rotation recommandée : secrets sessions toutes les 90 jours
# - Rotation recommandée : POSTGRES_PASSWORD, REDIS_PASSWORD : tous les 6 mois
# =============================================================================

# =============================================================================
# AVANCÉ / OPTIONNEL — réglages fins (valeurs par défaut déjà appliquées)
# Ne décommenter/modifier que pour personnaliser. Laissés vides = défaut du compose.
# =============================================================================

# ── Dify — performance & comportement ───────────────────────────────────────
DIFY_SERVER_WORKER_AMOUNT=1          # nb workers API (gunicorn)
DIFY_CELERY_WORKER_AMOUNT=           # nb workers Celery (vide = auto)
DIFY_WEB_PM2_INSTANCES=1             # instances frontend Next.js
DIFY_UPLOAD_FILE_SIZE_LIMIT=15       # taille max upload (Mo)
DIFY_UPLOAD_FILE_BATCH_LIMIT=5       # nb fichiers par batch
DIFY_LOG_OUTPUT_FORMAT=text          # text | json
DIFY_MARKETPLACE_ENABLED=true        # marketplace plugins (daemon plugin requis pour install)
DIFY_PIP_MIRROR_URL=                 # miroir pip (réseaux restreints)
DIFY_QDRANT_API_KEY=                 # clé API Qdrant si activée
DIFY_SCARF_NO_ANALYTICS=true         # désactive la télémétrie Scarf
DIFY_WEB_SENTRY_DSN=                 # Sentry frontend (vide = désactivé)
# Sandbox d'exécution de code
DIFY_SANDBOX_ENABLE_NETWORK=true     # accès réseau du sandbox (via ssrf-proxy)
DIFY_SANDBOX_WORKER_TIMEOUT=15       # timeout exécution (s)
# SSRF proxy
DIFY_SSRF_HTTP_PORT=3128
DIFY_SSRF_ALLOW_PRIVATE_IPS=         # autoriser IP privées (déconseillé)
DIFY_SSRF_ALLOW_PRIVATE_DOMAINS=     # autoriser domaines privés

# ── Langfuse — comportement & seed initial ──────────────────────────────────
LANGFUSE_TELEMETRY_ENABLED=false             # télémétrie produit Langfuse
LANGFUSE_EXPERIMENTAL_FEATURES=false
LANGFUSE_AUTH_DISABLE_SIGNUP=false           # bloquer l'inscription publique (mettre true en prod si SSO seul)
LANGFUSE_AUTH_DISABLE_PASSWORD=false         # désactiver login mot de passe (true = SSO obligatoire)
LANGFUSE_OIDC_ALLOW_EMAIL_LINK=true          # lier compte OIDC à un email existant
LANGFUSE_S3_BATCH_EXPORT_ENABLED=false       # exports batch S3 (audit/Comp AI)
LANGFUSE_INGESTION_QUEUE_DELAY_MS=           # tuning ingestion (vide = défaut)
LANGFUSE_INGESTION_CLICKHOUSE_WRITE_INTERVAL_MS=
# Email (notifications, invitations) — vide = désactivé
LANGFUSE_SMTP_URL=
LANGFUSE_EMAIL_FROM=
# Seed automatique au 1er démarrage (optionnel — sinon créer via l'UI)
LANGFUSE_INIT_ORG_ID=
LANGFUSE_INIT_ORG_NAME=
LANGFUSE_INIT_PROJECT_ID=
LANGFUSE_INIT_PROJECT_NAME=
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=
LANGFUSE_INIT_PROJECT_SECRET_KEY=
LANGFUSE_INIT_USER_EMAIL=
LANGFUSE_INIT_USER_NAME=
LANGFUSE_INIT_USER_PASSWORD=
